{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: compile",
      "type": "npm",
      "script": "compile",
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "npm: bundle (clean)",
      "type": "npm",
      "script": "bundle",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent"
      },
      "dependsOn": ["clean dist"]
    },
    {
      "label": "clean dist",
      "type": "shell",
      "command": "rm",
      "args": ["-rf", "dist/"],
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
