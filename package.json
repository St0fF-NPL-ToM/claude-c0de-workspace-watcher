{
  "name": "claude-c0de-workspace-watcher",
  "displayName": "Klaus'C0dehelfer",
  "description": "Passive filesystem awareness for Claude Code: tracks file changes and syncs with Claude's context",
  "version": "0.5.6-beta",
  "publisher": "theObsessedManiacs",
  "license": "Apache-2.0",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "claude",
    "workspace",
    "file-monitoring",
    "collaboration",
    "workspace-monitor",
    "file-tracking",
    "passive-awareness"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theObsessedManiacs/claude-c0de-workspace-watcher"
  },
  "bugs": {
    "url": "https://github.com/theObsessedManiacs/claude-c0de-workspace-watcher/issues"
  },
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "author": {
    "name": "Stefan Kaps",
    "url": "https://github.com/theObsessedManiacs"
  },
  "contributors": [
    {
      "name": "Claude Haiku 4.5 (Anthropic) — initial implementation, because it is SMART!",
      "url": "https://anthropic.com"
    }
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-workspace-monitor.openSettings",
        "title": "Klaus'C0dehelfer: Edit Settings"
      }
    ],
    "configuration": {
      "title": "Klaus'C0dehelfer",
      "properties": {
        "claude-workspace-monitor.awarenessMode": {
          "type": "string",
          "enum": [
            "none",
            "onDemand",
            "realTime"
          ],
          "enumDescriptions": [
            "No Claude coworking awareness",
            "On-Demand: Claude checks for changes on every prompt (efficient)",
            "Real-Time: Claude is notified on every file save (immediate)"
          ],
          "default": "none",
          "description": "Claude coworking awareness mode. Select 'On-Demand' or 'Real-Time' to enable and configure hooks.",
          "scope": "resource"
        },
        "claude-workspace-monitor.mtimesPath": {
          "type": "string",
          "default": "",
          "description": "Custom path for file modification times. Leave empty to use workspace .vscode/.workspaceChanges.json. Supports ${workspaceFolder} variable.",
          "scope": "resource"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.3.0"
  }
}
