{
  "name": "claude-c0de-workspace-watcher",
  "displayName": "Klaus'C0dehelfer",
  "description": "Passive filesystem awareness for Claude Code: tracks file changes and syncs with Claude's context",
  "version": "0.5.2-a1",
  "publisher": "theObsessedManiacs",
  "license": "Apache-2.0",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "claude",
    "workspace",
    "file-monitoring",
    "collaboration",
    "workspace-monitor",
    "file-tracking",
    "passive-awareness"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theObsessedManiacs/claude-c0de-workspace-watcher"
  },
  "bugs": {
    "url": "https://github.com/theObsessedManiacs/claude-c0de-workspace-watcher/issues"
  },
  "extensionDependencies": [
    "anthropic.claude-code"
  ],
  "author": {
    "name": "Stefan Kaps",
    "url": "https://github.com/theObsessedManiacs"
  },
  "contributors": [
    {
      "name": "Klaus Haiku (Anthropic Claude HAIKU 4.5) — initial implementation, because he is SMART!",
      "url": "https://anthropic.com"
    }
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/Klaus.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-c0de-workspace-watcher.openSettings",
        "title": "Klaus'C0dehelfer: Edit Settings"
      }
    ],
    "configuration": {
      "title": "Klaus'C0dehelfer",
      "properties": {
        "claude-c0de-workspace-watcher.awarenessMode": {
          "type": "string",
          "enum": [
            "none",
            "onDemand",
            "realTime"
          ],
          "enumDescriptions": [
            "No Claude coworking awareness",
            "On-Demand: Claude checks for changes on every prompt (efficient)",
            "Real-Time: Claude is notified on every file save (immediate)"
          ],
          "default": "none",
          "description": "Claude coworking awareness mode. Select 'On-Demand' or 'Real-Time' to enable and configure hooks.",
          "scope": "resource",
          "name": "MODE"
        },
        "claude-c0de-workspace-watcher.stateFileName": {
          "type": "string",
          "default": "KlausC0deHelferData",
          "description": "Filename stem for workspace state tracking (without .json extension). E.g., 'KlausC0deHelferData' stores as '.vscode/KlausC0deHelferData.json'. The .json extension is automatically appended.",
          "scope": "resource",
          "name": "FILE"
        },
        "claude-c0de-workspace-watcher.includePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.{cpp,h,hpp,c,py,ts,tsx,js,json,yaml,toml,md,txt,sh,cmake,asm}",
            "**/CMakeLists.txt"
          ],
          "description": "Glob patterns for files to monitor.",
          "scope": "resource",
          "name": "INCL"
        },
        "claude-c0de-workspace-watcher.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/[.]*",
            "**/build/**",
            "**/__pycache__/**",
            "**/node_modules/**",
            "**/logs/**",
            "**/*.o",
            "**/*.a",
            "**/*.so",
            "**/*.dll"
          ],
          "description": "Glob patterns for files to exclude from monitoring.",
          "scope": "resource",
          "name": "EXCL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "npm run bundle:ext && npm run bundle:hook",
    "bundle:ext": "esbuild src/KlausCodeHelfer.ts --bundle --outfile=dist/Klaus.js --external:vscode --platform=node --minify --sourcemap",
    "bundle:hook": "esbuild src/KlausHaken.ts --bundle --outfile=dist/KlausHaken.js --platform=node --minify --sourcemap",
    "compile": "tsc --noEmit",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "generate:config": "ts-node scripts/generatePackageConstants.ts",
    "prebuild": "npm run generate:config",
    "build": "tsc"
  },
  "dependencies": {
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "@tsconfig/bases": "^1.0.24",
    "@types/node": "^20.19.41",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
